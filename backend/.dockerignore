# Dependencies — reinstalled from package.json during image build
node_modules

# Frontend build output — mounted from the frontend container in production
dist

# Local uploads — mounted as a Docker volume in production
storage/uploads

# Test suites — not needed in production image
tests

# Environment files — never bake secrets into images
.env
.env.*
!.env.example
!.env.production.example

# Logs — written to stdout/stderr in containers, not to files
*.log
logs/

# Git
.git
.gitignore

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Dev tools
nodemon.json
