# ================================================================
# HELIO Platform — Environment Configuration Reference
# ================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ---- Core Server ----
NODE_ENV=development
PORT=5000

# Public-facing URLs (used for CORS, OAuth redirects, and API routing)
# In development: typically http://localhost:5000 and http://localhost:5173
# In production: your real domain e.g. https://api.helio.com and https://app.helio.com
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ---- Database ----
# MongoDB Atlas URI (must be a replica set for ACID transaction support)
# For local dev: mongodb://127.0.0.1:27017/helio
MONGO_URI=

# ---- JWT Authentication ----
# Use a cryptographically random 256-bit value. Example generation:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER use a placeholder in any environment.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_256BIT_SECRET

# ---- Google OAuth 2.0 ----
# From: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must be: ${BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Google Gemini AI ----
# From: aistudio.google.com → Get API Key
GEMINI_API_KEY=

# ---- Redis (Optional) ----
# Leave empty to disable Redis. If provided, Redis will be used for session caching.
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=

# ---- File Storage ----
# Options: local | cloudinary | s3
# local: stores files in backend/storage/uploads/
STORAGE_PROVIDER=local

# ---- Meta WhatsApp Cloud API ----
# From: developers.facebook.com → App Dashboard → WhatsApp
# Only required if ENABLE_WHATSAPP=true
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ---- Feature Flags ----
# Toggle platform capabilities. Set to 'true' or 'false'.
ENABLE_WHATSAPP=false
ENABLE_OCR=true
ENABLE_VOICE=true
ENABLE_GEMINI=true
ENABLE_EMAIL=false
ENABLE_ANALYTICS=true

# ---- Worker Process Topology ----
# Controls which background processes run in this Node.js instance.
# Options: all | api | worker | outbox-publisher | scheduler
# Use 'all' for local development (unified monolith).
# Use individual values for separate Docker containers in production.
PROCESS_TYPE=all

# ---- Logging ----
# Options: debug | info | warn | error
LOG_LEVEL=info

# ---- Worker Tuning ----
# Days ahead to generate dose instances for a patient's schedule
REMINDER_LOOKAHEAD_DAYS=7
# Minutes before dose time to send the first reminder
FOLLOWUP_DELAY_MINUTES=30
